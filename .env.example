# Supabase (required) — Dashboard → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key

# Inject into public/js/supabase-env.js:
#   node scripts/inject-supabase-config.js
# Local test:
#   npm run serve
# Discord OAuth is configured in Supabase Dashboard (not here)

# --- Legacy Express (optional, not used with Supabase) ---
# PORT=3000
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
